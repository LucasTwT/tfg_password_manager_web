{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "store:default",
    "clipboard-manager:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:**" },
        { "url": "https://localhost:**" },
        { "url": "http://127.0.0.1:**" }
      ]
    }
  ]
}
